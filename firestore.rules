rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Portal shared states - read is open for general public, write is enabled to allow synchronization
    match /portal_data/{id} {
      allow read, write: if true;
    }
  }
}
